      {
        "id": "30711506-763e-4748-b63b-e97a92881995",
        "name": "Separate the Tickets for Hash",
        "parameters": {
          "jsCode": "// Flatten banyak items iTop -> 1 item per tiket (Incident/UserRequest)\nconst allowed = new Set(['Incident', 'UserRequest']);\nconst seen = new Set();          // buat dedupe kalau ada duplikasi\nconst out = [];\n\n// helper: HTML -> text sederhana\nfunction htmlToText(html = '') {\n  return String(html)\n    .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '')\n    .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '')\n    .replace(/<br\\s*\\/?>/gi, '\\n')\n    .replace(/<\\/p>/gi, '\\n')\n    .replace(/<[^>]+>/g, '')\n    .replace(/\\r?\\n\\s*\\r?\\n/g, '\\n')\n    .trim();\n}\n\nfor (const it of items) {\n  const objs = it.json?.objects || {};\n  for (const [key, obj] of Object.entries(objs)) {\n    const cls = obj.class || (key.includes('::') ? key.split('::')[0] : 'Unknown');\n    if (!allowed.has(cls)) continue;\n\n    const f = obj.fields || {};\n    const id = String(f.id ?? obj.key ?? (key.split('::')[1] || ''));\n    const composite_id = `${cls}:${id}`;\n    if (seen.has(composite_id)) continue;  // dedupe antar items\n    seen.add(composite_id);\n\n    const html = f.description || '';\n    const text = htmlToText(html);\n\n    out.push({\n      json: {\n        // identitas untuk mapping & checkpoint\n        itop_class: cls,                 // \"Incident\" / \"UserRequest\"\n        itop_id: id,                     // e.g. \"6\"\n        itop_ref: f.ref || '',           // e.g. \"I-000006\" / \"R-000004\"\n        composite_id,                    // e.g. \"Incident:6\"\n        \n        service_name: f.servicesubcategory_name,\n        title: f.title || '',\n        description_html: html,\n        description_text: text,\n        status: f.status || f.status || '',\n        start_date: f.start_date || null,\n        last_update: f.last_update || null,\n        urgency: f.urgency || null,\n\n        // caller & org (berguna buat bikin ticket di osTicket)\n        caller_id: String(f.caller_id || ''),\n        caller_name: f.caller_id_friendlyname || (f.caller_name || ''),\n        org_id: String(f.org_id || ''),\n        org_name: f.org_name || (f.org_id_friendlyname || '')\n      }\n    });\n  }\n}\n\nreturn out;\n"
        },
