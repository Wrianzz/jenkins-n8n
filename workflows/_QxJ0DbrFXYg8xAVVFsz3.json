        "typeVersion": 2
      },
      {
        "id": "666f7e67-18f0-4a47-9ba6-78fa408c2c83",
        "name": "Sticky Note4",
        "parameters": {
          "content": "### Ambil List Finding (Verified) berdasarkan Product Name",
