      {
        "id": "93694614-3e24-4dc8-b7bd-470da28e5793",
        "name": "Extract Findings",
        "parameters": {
          "jsCode": "// n8n Code node (JavaScript)\n// Input: array items, tiap item.json bisa berbentuk { count, results: [...] }\n// Output: satu item per finding (menyalin objek finding apa adanya)\n\nconst out = [];\n\nfor (const item of items) {\n  const payload = item.json;\n\n  // Normalisasi supaya aman kalau suatu saat berbentuk array juga\n  const buckets = Array.isArray(payload) ? payload : [payload];\n\n  for (const b of buckets) {\n    const list = Array.isArray(b?.results) ? b.results : [];\n\n    for (const f of list) {\n      if (f && typeof f === 'object') {\n        // Kasus umum: results berisi objek finding lengkap\n        out.push({ json: f });\n      } else {\n        // Fallback kalau results berisi angka ID saja\n        out.push({ json: { finding_id: Number(f) } });\n      }\n    }\n  }\n}\n\nreturn out.length ? out : [{ json: { note: 'no findings found' } }];\n"
        },
