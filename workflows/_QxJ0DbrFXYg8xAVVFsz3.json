      {
        "id": "dfa98896-fb62-4741-897a-c59007a49d73",
        "name": "Get Product Name",
        "parameters": {
          "jsCode": "const out = [];\nconst seen = new Set();\n\nfunction pushName(name) {\n  if (typeof name === 'string' && name.trim() && !seen.has(name)) {\n    seen.add(name);\n    out.push({ json: { product_name: name } });\n  }\n}\n\nfor (const item of items) {\n  const payload = item.json;\n\n  // Normalisasi: bisa object {results: [...]} atau array [{results: [...]}]\n  const buckets = Array.isArray(payload) ? payload : [payload];\n\n  for (const b of buckets) {\n    // Ambil list product dari b.results (atau langsung b kalau sudah array of products)\n    const list = Array.isArray(b?.results) ? b.results : (Array.isArray(b) ? b : []);\n\n    for (const prod of list) {\n      pushName(prod?.name);\n    }\n  }\n}\n\n// Jika mau SATU item berisi array nama:\n// return [{ json: { product_names: out.map(i => i.json.product_name) } }];\n\nreturn out.length ? out : [{ json: { product_name: null, note: 'no products found' } }];\n"
        },
