      {
        "id": "970fec14-a118-4cfc-9eb0-e77a753c7863",
        "name": "Convert to HTML",
        "parameters": {
          "jsCode": "// Ambil dan rapikan deskripsi jadi HTML aman & rapi\nfunction escapeHTML(s='') {\n  return String(s)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#39;');\n}\n\nfunction linkify(s='') {\n  return s.replace(/\\bhttps?:\\/\\/[^\\s<>\"']+/g, (u) => `<a href=\"${u}\">${u}</a>`);\n}\n\nconst title = $json.title || '';\nconst severity = $json.severity || '';\nconst raw = $json.description || '';\n\n// 1) Normalisasi baris & whitespace\nlet txt = raw.replace(/\\r\\n/g, '\\n').replace(/\\t/g, ' ').trim();\n\n// 2) Escape HTML biar aman\ntxt = escapeHTML(txt);\n\n// 3) Markdown ringan → HTML (bold **...**)\ntxt = txt.replace(/\\*\\*(.+?)\\*\\*/g, '<b>$1</b>');\n\n// 4) Line break → <br/>\ntxt = txt.replace(/\\n/g, '<br/>');\n\n// 5) Link otomatis\ntxt = linkify(txt);\n\n// 6) Kurangi <br/> beruntun\ntxt = txt.replace(/(<br\\/?>\\s*){3,}/g, '<br/><br/>');\n\nconst header =\n  `<p><b>${escapeHTML(title)}</b> — Severity: ${escapeHTML(severity)}</p>`;\n\nconst finalHtml = `${header}<div>${txt}</div>`;\n\nreturn [{\n  json: {\n    ...$json,\n    description_html: finalHtml\n  }\n}];\n"
        },
        "position": [
          320,
          544
        ],
        "type": "n8n-nodes-base.code",
        "typeVersion": 2
