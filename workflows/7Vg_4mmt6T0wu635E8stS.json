      {
        "id": "5262ca9c-a4e6-4d44-9c1b-0e63efa41b3c",
        "name": "Split Deleted Files",
        "parameters": {
          "jsCode": "// SPLIT DELETED FILES (Agar delete satu per satu)\nconst deletedFiles = $('Compare Logic').first().json.deletedFiles;\nif (!deletedFiles || deletedFiles.length === 0) return [];\n\nreturn deletedFiles.map(filePath => {\n  return { json: { path: filePath } };\n});"
        },
