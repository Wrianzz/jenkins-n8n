      {
        "id": "e2353b98-0ee5-45e1-ab21-1f5360adadef",
        "name": "Send email",
        "parameters": {
          "fromEmail": "FTP TCL Mobile <noreply@satnusa.com>",
          "html": "={{ \n  (() => {\n    const data = $('Compare Logic').first().json;\n    \n    // Style dasar untuk font yang enak dibaca (Monospace untuk path file)\n    let html = `<div style=\"font-family: Arial, sans-serif; color: #333;\">`;\n    \n    html += `<h3>FTP Monitoring Report</h3>`;\n    html += `<p>${data.summary}</p>`;\n    html += `<hr style=\"border: 0; border-top: 1px solid #eee;\">`;\n\n    // 1. Logic New File (Warna Hijau)\n    if (data.newFiles && data.newFiles.length > 0) {\n      html += `<h4 style=\"color: #2e7d32; margin-bottom: 5px;\">✅ NEW FILES ADDED:</h4>`;\n      html += `<pre style=\"background: #f1f8e9; padding: 10px; border-radius: 5px; font-family: Consolas, monospace;\">`;\n      html += data.newFiles.join('\\n');\n      html += `</pre>`;\n    }\n\n    // 2. Logic Deleted File (Warna Merah)\n    if (data.deletedFiles && data.deletedFiles.length > 0) {\n      html += `<h4 style=\"color: #c62828; margin-bottom: 5px;\">❌ FILES DELETED:</h4>`;\n      html += `<pre style=\"background: #ffebee; padding: 10px; border-radius: 5px; font-family: Consolas, monospace;\">`;\n      html += data.deletedFiles.join('\\n');\n      html += `</pre>`;\n    }\n    html += `</div>`;\n    return html;\n  })() \n}}",
