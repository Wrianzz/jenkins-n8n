      {
        "id": "6401597b-0484-4d55-ab93-061a9653ed50",
        "name": "Compare Logic",
        "parameters": {
          "jsCode": "// 1. CURRENT FILES (FTP)\n// Ambil semua hasil scan dari semua folder\nconst allFtpItems = $('Get FTP Files').all();\n// Map ke path, lalu HAPUS DUPLIKAT dengan Set (jika ada overlap), lalu sort\nconst currentFiles = [...new Set(allFtpItems.map(item => item.json.path))].sort();\n\n// 2. EXISTING FILES (DB)\n// PENTING: Karena node DB berjalan berulang (looping), data DB akan terduplikasi.\n// Kita WAJIB melakukan de-duplikasi di sini agar tidak ada triple-count.\nconst allDbItems = $('Get DB Files').all();\nconst dbFiles = [...new Set(allDbItems.map(item => item.json.path))].sort();\n\n// 3. COMPARE\n// Logic filter biasa (sudah aman karena data di atas sudah bersih/unik)\nconst newFiles = currentFiles.filter(x => !dbFiles.includes(x));\nconst deletedFiles = dbFiles.filter(x => !currentFiles.includes(x));\n\n// Cek apakah ada perubahan\nconst hasChanges = (newFiles.length > 0 || deletedFiles.length > 0);\n\nreturn {\n  json: {\n    hasChanges,\n    newFiles,\n    deletedFiles,\n    // Kita kirim summary teks untuk dipakai di Email\n    summary: `Changes Detected (Added: ${newFiles.length}, Deleted: ${deletedFiles.length})`\n  }\n};"
        },
        "position": [
          -544,
          64
        ],
        "type": "n8n-nodes-base.code",
        "typeVersion": 2
      },
      {
        "id": "7da2c154-7e6f-4291-b42c-6dbda8c62615",
        "name": "If Changes Detected",
        "parameters": {
          "conditions": {
            "boolean": [
              {
                "value1": "={{ $json.hasChanges }}",
                "value2": true
              }
            ]
          }
        },
        "position": [
          -320,
          64
        ],
        "type": "n8n-nodes-base.if",
        "typeVersion": 1
      },
      {
        "id": "691ff60c-4c89-4fdf-b9af-f0a0d0443c6c",
        "name": "Split New Files",
        "parameters": {
          "jsCode": "// SPLIT NEW FILES (Agar insert satu per satu)\nconst newFiles = items[0].json.newFiles;\nif (!newFiles || newFiles.length === 0) return [];\n\nreturn newFiles.map(filePath => {\n  return { json: { path: filePath } };\n});"
        },
        "position": [
          -48,
          -160
        ],
        "type": "n8n-nodes-base.code",
        "typeVersion": 2
      },
      {
        "id": "8b7a8a8d-2b48-402e-bf96-d50b50f17c93",
        "name": "Insert New (No Params)",
        "parameters": {
          "additionalFields": {},
          "operation": "executeQuery",
          "query": "={{ \"INSERT INTO ftp_files (path) VALUES ('\" + $json.path + \"') ON CONFLICT (path) DO NOTHING;\" }}"
        },
        "position": [
