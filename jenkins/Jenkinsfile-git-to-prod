def guardOps

def gitOps

def deployOps

pipeline {
  agent any

  parameters {
    choice(
      name: 'PIPELINE_MODE',
      choices: ['DEV_TO_REPO', 'REPO_TO_PROD', 'DEV_TO_PROD'],
      description: 'Pilih mode pipeline: DEV_TO_REPO | REPO_TO_PROD | DEV_TO_PROD'
    )
  }

  environment {
    WORKFLOW_ID = '0dC7cf1RWepnziH2'

    SSH_CRED_ID  = 'n8n-cross-server-ssh'
    DEV_SSH_HOST = '192.168.56.52'
    DEV_SSH_USER = 'jenkins'
    DEV_SSH_PORT = '22'

    PROD_SSH_HOST = '192.168.56.51'
    PROD_SSH_USER = 'jenkins'
    PROD_SSH_PORT = '22'

    DEV_CONTAINER     = 'n8n-n8n-dev-1'
    DEV_PG_CONTAINER  = 'n8n-postgres-dev-1'
    PROD_CONTAINER    = 'n8n-n8n-prod-1'
    PROD_PG_CONTAINER = 'n8n-postgres-prod-1'

    REPO_HTTP = 'http://atlassian.satnusa.com:7990/scm/dvo/n8n-cicd-workflows.git'
    GIT_CRED_ID = 'bitbucket'
    APPROVER = 'morax'
  }

  stages {
    stage('Load shared library objects') {
      steps {
        script {
          guardOps = load 'jenkins/lib/PipelineGuard.groovy'
          gitOps = load 'jenkins/lib/GitWorkflowOps.groovy'
          deployOps = load 'jenkins/lib/DeploymentOps.groovy'
        }
      }
    }

    stage('Approval') {
      when {
        expression {
          params.PIPELINE_MODE in ['REPO_TO_PROD', 'DEV_TO_PROD']
        }
      }
      steps {
        script {
          guardOps.requestApproval(params.PIPELINE_MODE, env.WORKFLOW_ID, env.APPROVER)
        }
      }
    }

    stage('Checkout required files only') {
      steps {
        script {
          gitOps.checkoutRequiredFiles(env.REPO_HTTP, env.GIT_CRED_ID)
        }
      }
    }

    stage('Prepare workflow branch') {
      when {
        expression {
          params.PIPELINE_MODE in ['DEV_TO_REPO', 'DEV_TO_PROD']
        }
      }
      steps {
        script {
          gitOps.prepareWorkflowBranch(env.GIT_CRED_ID, env.WORKFLOW_ID)
        }
      }
    }

    stage('Dev -> Repo (export)') {
      when {
        expression {
          params.PIPELINE_MODE in ['DEV_TO_REPO', 'DEV_TO_PROD']
        }
      }
      steps {
        script {
          deployOps.exportWorkflowFromDev(env.SSH_CRED_ID, env.WORKFLOW_ID)
        }
      }
    }

    stage('Commit & push workflow file only') {
      when {
        expression {
          params.PIPELINE_MODE in ['DEV_TO_REPO', 'DEV_TO_PROD']
        }
      }
      steps {
        script {
          wrap([$class: 'BuildUser']) {
            env.authorName = env.BUILD_USER ?: 'Unknown'
            env.authorEmail = env.BUILD_USER_EMAIL ?: 'no-reply@example.com'
          }
          gitOps.commitAndPushWorkflowOnly(env.GIT_CRED_ID, env.WORKFLOW_ID, env.authorName, env.authorEmail)
        }
      }
    }

    stage('Promote workflow file to master only') {
      when {
        expression {
          params.PIPELINE_MODE in ['REPO_TO_PROD', 'DEV_TO_PROD']
        }
      }
      steps {
        script {
          wrap([$class: 'BuildUser']) {
            env.authorName = env.BUILD_USER ?: 'Unknown'
            env.authorEmail = env.BUILD_USER_EMAIL ?: 'no-reply@example.com'
          }
          gitOps.promoteWorkflowToMaster(env.GIT_CRED_ID, env.WORKFLOW_ID, env.authorName, env.authorEmail)
        }
      }
    }

    stage('Repo -> Prod (promote creds + deploy)') {
      when {
        expression {
          params.PIPELINE_MODE in ['REPO_TO_PROD', 'DEV_TO_PROD']
        }
      }
      steps {
        script {
          deployOps.deployFromRepoToProd(env.SSH_CRED_ID, env.WORKFLOW_ID)
        }
      }
    }
  }
}
