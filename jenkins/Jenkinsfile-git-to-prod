pipeline {
  agent any

  parameters {
    choice(
      name: 'PIPELINE_MODE',
      choices: ['DEV_TO_REPO', 'REPO_TO_PROD', 'DEV_TO_PROD'],
      description: 'Pilih mode pipeline: DEV_TO_REPO | REPO_TO_PROD | DEV_TO_PROD'
    )
  }

  environment {
    WORKFLOW_ID = '_QxJ0DbrFXYg8xAVVFsz3'

    SSH_CRED_ID  = 'n8n-cross-server-ssh'
    DEV_SSH_HOST = 'dev-n8n.internal'
    DEV_SSH_USER = 'ubuntu'
    DEV_SSH_PORT = '22'

    PROD_SSH_HOST = 'prod-n8n.internal'
    PROD_SSH_USER = 'ubuntu'
    PROD_SSH_PORT = '22'

    DEV_CONTAINER     = 'n8n-dev-n8n-dev-1'
    PROD_CONTAINER    = 'n8n-prod-n8n-prod-1'
    PROD_PG_CONTAINER = 'n8n-prod-postgres-prod-1'

    REPO_HTTPS = 'https://github.com/Wrianzz/jenkins-n8n.git'
    GIT_CRED_ID = 'jenkins-n8n'
  }

  stages {
    stage('Approval') {
      when {
        expression {
          params.PIPELINE_MODE in ['REPO_TO_PROD', 'DEV_TO_PROD']
        }
      }
      steps {
        input message: "Mode ${params.PIPELINE_MODE}: yakin lanjut promote 1 file workflow (wf/${env.WORKFLOW_ID}) ke main + deploy ke PROD?",
              ok: 'Approve & Continue',
              submitter: 'morax'
      }
    }

    stage('Checkout required files only') {
      steps {
        checkout([$class: 'GitSCM',
          branches: [[name: '*/main']],
          userRemoteConfigs: [[
            url: "${REPO_HTTPS}",
            credentialsId: "${GIT_CRED_ID}"
          ]],
          extensions: [
            [$class: 'SparseCheckoutPaths', sparseCheckoutPaths: [
              [path: 'scripts/'],
              [path: 'workflows/' + env.WORKFLOW_ID + '.json'],
              [path: 'jenkins/']
            ]]
          ]
        ])
      }
    }

    stage('Prepare workflow branch') {
      when {
        expression {
          params.PIPELINE_MODE in ['DEV_TO_REPO', 'DEV_TO_PROD']
        }
      }
      steps {
        sh '''
          set -e
          git fetch origin main
          git checkout -B "wf/${WORKFLOW_ID}" origin/main
        '''
      }
    }

    stage('Dev -> Repo (export)') {
      when {
        expression {
          params.PIPELINE_MODE in ['DEV_TO_REPO', 'DEV_TO_PROD']
        }
      }
      steps {
        withCredentials([sshUserPrivateKey(
          credentialsId: "${SSH_CRED_ID}",
          keyFileVariable: 'SSH_KEY_FILE'
        )]) {
          sh '''
            set -e
            chmod +x scripts/export-to-git.sh
            export SSH_KEY_FILE
            scripts/export-to-git.sh "$WORKFLOW_ID"
          '''
        }
      }
    }

    stage('Commit & push workflow file only') {
      when {
        expression {
          params.PIPELINE_MODE in ['DEV_TO_REPO', 'DEV_TO_PROD']
        }
      }
      steps {
        withCredentials([usernamePassword(
          credentialsId: "${GIT_CRED_ID}",
          usernameVariable: 'GH_USER',
          passwordVariable: 'GH_PAT'
        )]) {
          sh '''
            set -e
            set +x

            git status
            git config user.email "jenkins@local"
            git config user.name  "jenkins"

            # pastikan branch workflow ini hanya menyimpan 1 file workflow target
            find workflows -maxdepth 1 -type f -name '*.json' ! -name "${WORKFLOW_ID}.json" -delete || true

            git add -A workflows/
            git commit -m "export workflow ${WORKFLOW_ID} from dev" || echo "No changes"

            git remote set-url origin "https://${GH_USER}:${GH_PAT}@github.com/Wrianzz/jenkins-n8n.git"
            git push origin HEAD:"wf/${WORKFLOW_ID}"
          '''
        }
      }
    }

    stage('Promote workflow file to main only') {
      when {
        expression {
          params.PIPELINE_MODE in ['REPO_TO_PROD', 'DEV_TO_PROD']
        }
      }
      steps {
        withCredentials([usernamePassword(
          credentialsId: "${GIT_CRED_ID}",
          usernameVariable: 'GH_USER',
          passwordVariable: 'GH_PAT'
        )]) {
          sh '''
            set -e
            set +x

            git config user.email "jenkins@local"
            git config user.name  "jenkins"
            git remote set-url origin "https://${GH_USER}:${GH_PAT}@github.com/Wrianzz/jenkins-n8n.git"

            git fetch origin main "wf/${WORKFLOW_ID}"
            git checkout -B main origin/main
            git checkout "origin/wf/${WORKFLOW_ID}" -- "workflows/${WORKFLOW_ID}.json"

            if git diff --quiet HEAD -- "workflows/${WORKFLOW_ID}.json"; then
              echo "[INFO] workflows/${WORKFLOW_ID}.json already up to date in main"
            else
              git add "workflows/${WORKFLOW_ID}.json"
              git commit -m "promote workflow ${WORKFLOW_ID} from wf branch to main"
              git push origin HEAD:main
            fi
          '''
        }
      }
    }

    stage('Repo -> Prod (promote creds + deploy)') {
      when {
        expression {
          params.PIPELINE_MODE in ['REPO_TO_PROD', 'DEV_TO_PROD']
        }
      }
      steps {
        withCredentials([sshUserPrivateKey(
          credentialsId: "${SSH_CRED_ID}",
          keyFileVariable: 'SSH_KEY_FILE'
        )]) {
          sh '''
            set -e
            chmod +x scripts/deploy-from-git.sh scripts/promote-creds.sh
            export SSH_KEY_FILE
            scripts/deploy-from-git.sh "$WORKFLOW_ID"
          '''
        }
      }
    }
  }
}
