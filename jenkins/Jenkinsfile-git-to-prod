pipeline {
  agent any

  parameters {
    choice(
      name: 'PIPELINE_MODE',
      choices: ['DEV_TO_REPO', 'REPO_TO_PROD', 'DEV_TO_PROD'],
      description: 'Pilih mode pipeline: DEV_TO_REPO | REPO_TO_PROD | DEV_TO_PROD'
    )
  }

  environment {
    WORKFLOW_ID = '0dC7cf1RWepnziH2'
    
    SSH_CRED_ID  = 'n8n-cross-server-ssh'
    DEV_SSH_HOST = '192.168.56.52'
    DEV_SSH_USER = 'jenkins'
    DEV_SSH_PORT = '22'

    PROD_SSH_HOST = '192.168.56.51'
    PROD_SSH_USER = 'jenkins'
    PROD_SSH_PORT = '22'

    DEV_CONTAINER     = 'n8n-n8n-dev-1'
    PROD_CONTAINER    = 'n8n-n8n-prod-1'
    PROD_PG_CONTAINER = 'n8n-postgres-prod-1'

    REPO_HTTP = 'http://atlassian.satnusa.com:7990/scm/dvo/n8n-cicd-workflows.git'
    GIT_CRED_ID = 'bitbucket'
  }

  stages {
    stage('Approval') {
      when {
        expression {
          params.PIPELINE_MODE in ['REPO_TO_PROD', 'DEV_TO_PROD']
        }
      }
      steps {
        input message: "Mode ${params.PIPELINE_MODE}: yakin lanjut promote 1 file workflow (workflow/${env.WORKFLOW_ID}) ke master + deploy ke PROD?",
              ok: 'Approve & Continue',
              submitter: 'morax'
      }
    }

    stage('Checkout required files only') {
      steps {
        checkout([$class: 'GitSCM',
          branches: [[name: '*/master']],
          userRemoteConfigs: [[
            url: "${REPO_HTTP}",
            credentialsId: "${GIT_CRED_ID}"
          ]],
          extensions: [
            [$class: 'SparseCheckoutPaths', sparseCheckoutPaths: [
              [path: 'scripts/'],
              [path: 'workflows/'],
              [path: 'jenkins/']
            ]]
          ]
        ])
      }
    }

    stage('Prepare workflow branch') {
      when {
        expression {
          params.PIPELINE_MODE in ['DEV_TO_REPO', 'DEV_TO_PROD']
        }
      }
      steps {
        withCredentials([usernamePassword(
          credentialsId: "${GIT_CRED_ID}",
          usernameVariable: 'GH_USER',
          passwordVariable: 'GH_PASS'
        )]) {
        sh '''
          set -e
          git remote set-url origin "http://${GH_USER}:${GH_PASS}@atlassian.satnusa.com:7990/scm/dvo/n8n-cicd-workflows.git"
          git fetch origin master

          # selalu mulai dari origin/master agar script pipeline tersedia saat export
          git checkout -B "workflow/${WORKFLOW_ID}" origin/master
        '''
        }
      }
    }

    stage('Dev -> Repo (export)') {
      when {
        expression {
          params.PIPELINE_MODE in ['DEV_TO_REPO', 'DEV_TO_PROD']
        }
      }
      steps {
        withCredentials([sshUserPrivateKey(
          credentialsId: "${SSH_CRED_ID}",
          keyFileVariable: 'SSH_KEY_FILE'
        )]) {
          sh '''
            set -e
            chmod +x scripts/export-to-git.sh
            export SSH_KEY_FILE
            scripts/export-to-git.sh "$WORKFLOW_ID"
          '''
        }
      }
    }

    stage('Commit & push workflow file only') {
      when {
        expression {
          params.PIPELINE_MODE in ['DEV_TO_REPO', 'DEV_TO_PROD']
        }
      }
      steps {
        script{
          wrap([$class: 'BuildUser']) {
            env.authorName = env.BUILD_USER ?: 'Unknown'
            env.authorEmail = env.BUILD_USER_EMAIL ?: 'no-reply@example.com'
          }
        }
        withCredentials([usernamePassword(
          credentialsId: "${GIT_CRED_ID}",
          usernameVariable: 'GH_USER',
          passwordVariable: 'GH_PASS'
        )]) {
          sh '''
            set -e
            set +x

            git status
            git config user.email "${authorEmail}"
            git config user.name  "${authorName}"

            # branch workflow ini hanya berisi folder workflows + 1 file workflow target
            find . -mindepth 1 -maxdepth 1 ! -name '.git' ! -name 'workflows' -exec rm -rf {} +
            find workflows -maxdepth 1 -type f -name '*.json' ! -name "${WORKFLOW_ID}.json" -delete || true

            git add -A .
            if git diff --cached --quiet; then
              echo "[INFO] No changes to commit for workflows/${WORKFLOW_ID}.json"
            else
              git commit -m "export workflow ${WORKFLOW_ID} from dev"
            fi

            git remote set-url origin "http://${GH_USER}:${GH_PASS}@atlassian.satnusa.com:7990/scm/dvo/n8n-cicd-workflows.git"
            if git ls-remote --exit-code --heads origin "workflow/${WORKFLOW_ID}" >/dev/null 2>&1; then
              git push --force-with-lease origin HEAD:"workflow/${WORKFLOW_ID}"
            else
              git push origin HEAD:"workflow/${WORKFLOW_ID}"
            fi
          '''
        }
      }
    }

    stage('Promote workflow file to master only') {
      when {
        expression {
          params.PIPELINE_MODE in ['REPO_TO_PROD', 'DEV_TO_PROD']
        }
      }
      steps {
        script{
          wrap([$class: 'BuildUser']) {
            env.authorName = env.BUILD_USER ?: 'Unknown'
            env.authorEmail = env.BUILD_USER_EMAIL ?: 'no-reply@example.com'
          }
        }
        withCredentials([usernamePassword(
          credentialsId: "${GIT_CRED_ID}",
          usernameVariable: 'GH_USER',
          passwordVariable: 'GH_PASS'
        )]) {
          sh '''
            set -e
            set +x

            git config user.email "${authorEmail}"
            git config user.name  "${authorName}"
            git remote set-url origin "http://${GH_USER}:${GH_PASS}@atlassian.satnusa.com:7990/scm/dvo/n8n-cicd-workflows.git"

            git fetch origin master "workflow/${WORKFLOW_ID}"
            git checkout -B master origin/master
            git checkout "origin/workflow/${WORKFLOW_ID}" -- "workflows/${WORKFLOW_ID}.json"

            if git diff --quiet HEAD -- "workflows/${WORKFLOW_ID}.json"; then
              echo "[INFO] workflows/${WORKFLOW_ID}.json already up to date in master"
            else
              git add "workflows/${WORKFLOW_ID}.json"
              git commit -m "promote workflow ${WORKFLOW_ID} from workflow branch to master"
              git push origin HEAD:master
            fi
          '''
        }
      }
    }

    stage('Repo -> Prod (promote creds + deploy)') {
      when {
        expression {
          params.PIPELINE_MODE in ['REPO_TO_PROD', 'DEV_TO_PROD']
        }
      }
      steps {
        withCredentials([sshUserPrivateKey(
          credentialsId: "${SSH_CRED_ID}",
          keyFileVariable: 'SSH_KEY_FILE'
        )]) {
          sh '''
            set -e
            chmod +x scripts/deploy-from-git.sh scripts/promote-creds.sh
            export SSH_KEY_FILE
            scripts/deploy-from-git.sh "$WORKFLOW_ID"
          '''
        }
      }
    }
  }
  post{
    always{
      script{
        cleanWs()
      }
    }
  }
}
